<%= form_with(model: membership_history) do |form| %>
  <% if membership_history.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(membership_history.errors.count, "error") %> prohibited this membership_history from being saved:</h2>

      <ul>
        <% membership_history.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
